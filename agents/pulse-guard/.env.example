# Pulse Guard — Environment Variables
# Copy this file to .env and fill in your values before running.

# --- Required: Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Required: Internal Auth ---
# A shared secret between FastAPI and Streamlit.
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_KEY=your-secure-internal-key-here

# --- Optional: LLM Config ---
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=1024

# --- Optional: Server ---
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
